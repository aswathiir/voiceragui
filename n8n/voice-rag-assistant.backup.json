[{"updatedAt":"2026-04-30T03:31:24.829Z","createdAt":"2026-04-25T06:38:28.618Z","id":"5L1WSTPfyCGTXXRd","name":"Voice RAG Assistant","description":null,"active":true,"isArchived":false,"nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":24}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[1552,1040],"id":"da1e3633-1252-49d0-ad4d-6446316e1d36","name":"Schedule Trigger"},{"parameters":{"method":"POST","url":"https://api.firecrawl.dev/v1/scrape","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Authorization","value":"Bearer fc-33292f877b464f138f726328af2474c8"}]},"sendBody":true,"specifyBody":"json","jsonBody":"{\n  \"url\": \"https://www.ncw.gov.in/publications/women-centric-schemes-by-different-ministries-of-government-of-india-goi/\",\n  \"formats\": [\"markdown\"],\n  \"onlyMainContent\": true,\n  \"waitFor\": 3000\n}\n","options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.3,"position":[1776,1040],"id":"8b74ad92-5c8e-4138-8f60-4e3c7ba54d0f","name":"HTTP Request"},{"parameters":{"jsCode":"const data = $input.item.json.data;\n\nif (!data || !data.markdown) {\n  throw new Error('Firecrawl returned no markdown. Check the API key and target URL.');\n}\n\nreturn {\n  json: {\n    data: data.markdown,\n    url: data.metadata?.url || 'https://www.ncw.gov.in/publications/women-centric-schemes-by-different-ministries-of-government-of-india-goi/',\n    title: data.metadata?.title || 'Women Centric Schemes - NCW'\n  }\n};\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2000,1040],"id":"f609f721-7ca8-496d-942f-19f7e1d540b4","name":"Extract Markdown"},{"parameters":{"mode":"insert","pineconeIndex":{"__rl":true,"value":"vad","mode":"list","cachedResultName":"vad"},"options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","typeVersion":1.3,"position":[2256,1040],"id":"edd66438-dc32-442f-b1d3-10511d70f5b6","name":"Pinecone Vector Store","credentials":{"pineconeApi":{"id":"O6H56aGQyE10U