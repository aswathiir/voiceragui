 be natural and concise.\n6. Never make up scheme names, eligibility criteria, amounts, or procedures."}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3,"position":[1920,1584],"id":"ea6f31e6-69ec-46e5-9780-d832a7b3e1bb","name":"AI Agent"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{"temperature":0.7}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[1920,1808],"id":"a30fe6f7-8b0f-4c9a-902c-80dfee7266ec","name":"Groq Chat Model","credentials":{"groqApi":{"id":"SVQxnuJ75821tQzB","name":"Groq account"}}},{"parameters":{"mode":"retrieve-as-tool","toolDescription":"Search the knowledge base to find relevant information for the user's question. Always use this before answering.","pineconeIndex":{"__rl":true,"value":"vad","mode":"id"},"topK":3,"options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","typeVersion":1.3,"position":[2160,1776],"id":"81ba7bd7-9d5b-4e52-b0a4-b3b840188601","name":"Pinecone Vector Store1","credentials":{"pineconeApi":{"id":"O6H56aGQyE10Uqog","name":"PineconeApi account"}}},{"parameters":{"model":"=nomic-embed-text:latest"},"type":"@n8n/n8n-nodes-langchain.embeddingsOllama","typeVersion":1,"position":[2416,1904],"id":"46c0ad70-e205-4187-a281-d3971a0492f4","name":"Embeddings Ollama1","credentials":{"ollamaApi":{"id":"brLXyU4S8qdGYkEW","name":"Ollama account"}}},{"parameters":{"jsCode":"const toolCallId = $('Webhook').item.json.body.message.toolCallList[0].id;\nconst agentOutput = $('AI Agent').item.json.output;\n\nif (!toolCallId) {\n  throw new Error('toolCallId missing from VAPI payload. Check webhook body structure.');\n}\n\nconst cleanResult = agentOutput\n  .replace(/\\n/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nreturn {\n  json: {\n    results: [\n      {\n        toolCallId: toolCallId,\n        result: cleanResult\n      }\n    ]\n  }\n};\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2336,1584],"id":"c5754f6c-3380-4461-b33b-915b7b57a3e0","name":"Format VAPI Res