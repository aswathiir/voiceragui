# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Vapi (Voice AI) ──────────────────────────────────────────────────────────
# Get these from https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PRIVATE_API_KEY=your_vapi_private_api_key_here

# Phone number ID registered in Vapi (used for outbound calls on Live Call page)
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# ── n8n Webhooks ─────────────────────────────────────────────────────────────
# Public-facing URL (e.g. via ngrok) — used by the browser to reach n8n
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-ngrok-subdomain.ngrok-free.app/webhook/voice-rag-query

# Server-side URL — used by the Next.js API proxy route (no CORS issues)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/voice-rag-query

# Dedicated webhook for Knowledge-Base file/URL ingestion (5-stage pipeline)
# n8n should POST progress callbacks to {origin}/api/webhooks/n8n with:
#   { fileId, stage: 'uploading'|'parsing'|'chunking'|'embedding'|'indexed'|'failed',
#     progress, chunkCount?, vectorCount?, errorMessage? }
# Falls back to N8N_WEBHOOK_URL if unset.
N8N_KB_WEBHOOK_URL=http://localhost:5678/webhook/kb-ingest

# Optional — shared secret n8n must echo back as ?secret= on calls to
# /api/webhooks/n8n. Without it that endpoint accepts any caller.
# N8N_WEBHOOK_SECRET=your_webhook_secret_here

# ── Pinecone (Vector DB) ─────────────────────────────────────────────────────
# Get your API key from https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=your_pinecone_index_name_here

# ── Groq (LLM — call analysis, sentiment, top-questions) ────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Auth / Session ────────────────────────────────────────────────────────────
# Random secret used to sign the session cookie — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=your_random_session_secret_here

# ── Stripe (Optional — Phase 3 billing) ──────────────────────────────────────
# Enables real Stripe billing in /admin/overview; falls back to empty state if unset.
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
