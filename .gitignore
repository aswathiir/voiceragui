.env
.env.local
.env.*.local
.env.development
.env.production

# ── Runtime / local data ─────────────────────────────────────────────────────
.data/

# ── IDE / editor specific ─────────────────────────────────────────────────────
.claude/
.design-sync/
.ds-sync/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
